                <ul class="docs-list">
                    <li>Trade Licence (30-day validity; company registered in UAE/Saudi Arabia/Egypt) or Freelance/Data Certificate</li>
                    <li>VAT Certificate (issued in UAE/KSA/Egypt)</li>
                    <li>Valid identity (Passport, Emirates/Saudi/Egyptian ID)</li>
                    <li>Bank account details (Bank statement, Cancelled cheque, Bank account, etc.)</li>
                    <li>Valid tax card (mandatory in Egypt)</li>
                </ul>
            </div>
            <!-- International Sellers -->
            <div class="docs-card">
                <div class="docs-card-header">
